# PeerJS Signaling Server Configuration
# Скопируй этот файл как .env и заполни значения

# Хост сигнального сервера (IP или домен домашнего сервера)
# Если не задано — используется публичный 0.peerjs.com (fallback)
VITE_PEER_HOST=

# Порт сигнального сервера
VITE_PEER_PORT=9000

# Использовать WSS/HTTPS (true/false)
VITE_PEER_SECURE=false

# Пример для локальной разработки:
# VITE_PEER_HOST=localhost
# VITE_PEER_PORT=9000
# VITE_PEER_SECURE=false

# Пример для домашнего сервера (продакшен):
# VITE_PEER_HOST=192.168.1.100
# VITE_PEER_PORT=9000
# VITE_PEER_SECURE=false
